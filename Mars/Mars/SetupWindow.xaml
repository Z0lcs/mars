<Window x:Class="Vadász_Mars_Dénes.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mars Rover - Küldetés Beállítása" Height="350" Width="550" 
        Background="#2C2C2C" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="KÜLDETÉS PARAMÉTEREI" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Térkép fájl (.csv):" Foreground="#BDC3C7" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="MapPathTextBox" IsReadOnly="True" Margin="5,0" Padding="5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Grid.Column="2" Content="Tallózás" Click="TallozasMap_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mentés helye:" Foreground="#BDC3C7" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="LogFolderPathTextBox" IsReadOnly="True" Margin="5,0" Padding="5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            <Button Grid.Column="2" Content="Tallózás" Click="TallozasMappa_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Időkorlát (Óra):" Foreground="#BDC3C7" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="TimeTextBox" Text="72" Margin="5,0,0,0" Padding="5" Background="#34495E" Foreground="White" BorderThickness="0" Width="80" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="(Minimum 24 óra)" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="95,0,0,0"/>
        </Grid>

        <Button Grid.Row="5" Content="🚀 SZIMULÁCIÓ INDÍTÁSA" Click="Start_Click" 
                Background="#27AE60" Foreground="White" FontSize="16" FontWeight="Bold" 
                Height="45" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</Window>