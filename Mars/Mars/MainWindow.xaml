<Window x:Class="Vadász_Mars_Dénes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf" 
        Title="Mars Vadász - Rover Térkép &amp; Dashboard" Height="900" Width="1400" Background="#121212"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Width" Value="380"/>
            <Setter Property="Height" Value="260"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleStyle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="lvc:Axis">
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <Style TargetType="lvc:Separator">

            <Setter Property="Stroke" Value="#333333"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatText" Text="Térkép betöltése..." Foreground="#E0E0E0" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                    <TextBlock Text="{Binding ElementName=speedSlider, Path=Value, StringFormat='Sebesség: {0:F1}x'}" 
               Foreground="White" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>

                    <Slider x:Name="speedSlider" 
            Minimum="0.5" 
            Maximum="5.0" 
            Value="1.0" 
            TickFrequency="0.5" 
            IsSnapToTickEnabled="True"
            Width="200" Margin="5"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="AutoPlayGomb" Content="▶ Lejátszás" Click="AutoPlay_Click" 
                        Background="#27AE60" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand" Visibility="Collapsed"/>
            </Grid>

            <CheckBox Grid.Row="1" x:Name="TrailToggle" Content="Nyomvonal megjelenítése 👣" IsChecked="True" Foreground="#BDC3C7" Margin="0,0,0,10"/>

            <Border Grid.Row="2" BorderBrush="#34495E" BorderThickness="3" CornerRadius="5" Background="#000000">
                <Viewbox Stretch="Uniform">
                    <ItemsControl x:Name="MapDisplay" Width="500" Height="500">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="50" Columns="50"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0.1">
                                    <Image Source="{Binding ImageSource, Mode=OneWay}" ToolTip="{Binding Coordinates}" Stretch="Uniform"/>
                                    <Ellipse Fill="#E74C3C" Width="4" Height="4" Opacity="0.8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding HasVisited}" Value="True"/>
                                                            <Condition Binding="{Binding ElementName=TrailToggle, Path=IsChecked}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Viewbox>
            </Border>
        </Grid>

        <Expander Grid.Column="1" ExpandDirection="Left" IsExpanded="False" Background="#181818" BorderBrush="#333">
            <Expander.Header>
                <TextBlock Text="📊 DASHBOARD" Foreground="#AAAAAA" FontWeight="Bold">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Expander.Header>

            <Border Width="820" Background="#121212" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="61*"/>
                                    <ColumnDefinition Width="293*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Akkumulátor Szint (%)" Style="{StaticResource TitleStyle}" Grid.Column="1" HorizontalAlignment="Left" Margin="45,0,0,10"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding AkkuSeries}" LegendLocation="None" Grid.ColumnSpan="2">
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0" MaxValue="100"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sebességfokozatok" Style="{StaticResource TitleStyle}"/>

                                <lvc:CartesianChart Grid.Row="1" Series="{Binding SebessegSeries}" Foreground="White">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding SebessegLabels}">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Step="1" StrokeThickness="0" />
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>

                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0" />
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Összegyűjtött Ásványok (db)" Style="{StaticResource TitleStyle}"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding AsvanySeries}" LegendLocation="None">
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding TeljesitmenySeries}" LegendLocation="Top" Foreground="White">
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Labels="{Binding TeljesitmenyLabels}"/>
                                    </lvc:CartesianChart.AxisY>
                                    <lvc:CartesianChart.SeriesColors>
                                        <lvc:ColorsCollection>
                                            <Color>#2ECC71</Color>
                                            <Color>#800080</Color>
                                        </lvc:ColorsCollection>
                                    </lvc:CartesianChart.SeriesColors>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Bányászat Napszakonként" Style="{StaticResource TitleStyle}"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding NapszakSeries}" LegendLocation="Bottom" Foreground="White">
                                    <lvc:CartesianChart.SeriesColors>
                                        <lvc:ColorsCollection>
                                            <Color>#F1C40F</Color>
                                            <Color>#34495E</Color>
                                        </lvc:ColorsCollection>
                                    </lvc:CartesianChart.SeriesColors>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>



                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Tevékenységek Megoszlása" Style="{StaticResource TitleStyle}"/>
                                <lvc:PieChart Grid.Row="1" Series="{Binding StatuszSeries}" LegendLocation="Bottom" InnerRadius="40" Foreground="White"/>
                            </Grid>
                        </Border>

                    </WrapPanel>
                </ScrollViewer>
            </Border>
        </Expander>
    </Grid>
</Window>